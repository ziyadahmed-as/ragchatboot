# Inherit root .gitignore — this file adds backend-specific rules

# Virtual environment
env/
venv/
.venv/

# Environment secrets
.env
.env.*
!.env.example

# Django
db.sqlite3
db.sqlite3-journal
*.log
local_settings.py
media/
staticfiles/
static_root/

# Python cache
__pycache__/
*.py[cod]
*.pyo

# pytest
.pytest_cache/
.coverage
htmlcov/

# SQL dumps
*.sql
*.dump

# Whisper model weights
*.pt
*.bin
models/
